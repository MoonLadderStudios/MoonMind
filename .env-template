# Deployment Settings
FASTAPI_RELOAD=""
INIT_DATABASE="true"
JWT_SECRET_KEY="replace_with_a_strong_random_jwt_secret"
ENCRYPTION_MASTER_KEY="replace_with_a_strong_random_encryption_key"
FERNET_KEY=""
LANGCHAIN_API_KEY=""
LocalData=""

# Docker-outside-Docker / container task execution
ORCHESTRATOR_DOCKER_HOST="unix:///var/run/docker.sock"
MOONMIND_WORKDIR="/work/agent_jobs"
MOONMIND_AGENT_WORKSPACES_VOLUME_NAME="agent_workspaces"
CODEX_VOLUME_PATH="/home/app/.codex"
CODEX_HOME="/home/app/.codex"
MOONMIND_WORKER_CAPABILITIES="codex,git,gh,docker,proposals_write"
MOONMIND_UNREAL_CCACHE_VOLUME_NAME="unreal_ccache_volume"
MOONMIND_UNREAL_UBT_VOLUME_NAME="unreal_ubt_volume"

LANGCHAIN_PROJECT="MoonMind"
LANGCHAIN_TRACING_V2="true"
MODEL_CACHE_REFRESH_INTERVAL=3600
MODEL_CACHE_REFRESH_INTERVAL_SECONDS=3600
MODEL_DIRECTORY="/app/model_data"
HF_ACCESS_TOKEN=""
OLLAMA_BASE_URL="http://ollama:11434"
OLLAMA_CHAT_MODEL="devstral:24b"
OLLAMA_EMBEDDINGS_DIMENSIONS=3584
OLLAMA_EMBEDDING_MODEL="hf.co/qwen/gte-Qwen2-7B-instruct-GGUF:Q6_K"
OLLAMA_ENABLED="false"
OLLAMA_KEEP_ALIVE="-1m"
OLLAMA_MODES="chat"
OPENHANDS__LLM__API_KEY=""
POSTGRES_VERSION=17
CELERY_BROKER_URL="amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672//"
CELERY_RESULT_BACKEND="db+postgresql://postgres:${POSTGRES_PASSWORD}@api-db:5432/moonmind"
CELERY_DEFAULT_QUEUE="moonmind.jobs"
CELERY_DEFAULT_EXCHANGE="moonmind.jobs"
CELERY_DEFAULT_ROUTING_KEY="moonmind.jobs"
# Canonical aliases (optional): WORKFLOW_DEFAULT_QUEUE / WORKFLOW_DEFAULT_EXCHANGE / WORKFLOW_DEFAULT_ROUTING_KEY

# Workflow Celery overrides (Codex automation)
# Leave blank to reuse the main Celery broker credentials; override for a dedicated broker if desired.
# Example: WORKFLOW_CELERY_BROKER_URL="amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:5672//"
WORKFLOW_CELERY_BROKER_URL=""
# Legacy aliases:
# SPEC_WORKFLOW_CELERY_BROKER_URL=""
# Leave blank to reuse the main Celery result backend; override when pointing at a managed Postgres instance.
# Example: WORKFLOW_CELERY_RESULT_BACKEND="db+postgresql://postgres:${POSTGRES_PASSWORD}@api-db:5432/moonmind"
WORKFLOW_CELERY_RESULT_BACKEND=""
# Legacy aliases:
# SPEC_WORKFLOW_CELERY_RESULT_BACKEND=""
WORKFLOW_CODEX_QUEUE="codex"
# Legacy alias:
# SPEC_WORKFLOW_CODEX_QUEUE="codex"
WORKFLOW_GITHUB_REPOSITORY="MoonLadderStudios/MoonMind"
# Legacy aliases (optional): SPEC_WORKFLOW_GITHUB_REPOSITORY
WORKFLOW_GIT_USER_NAME=""
WORKFLOW_GIT_USER_EMAIL=""
WORKFLOW_ARTIFACT_ROOT="var/artifacts/spec_workflows"
# Legacy aliases:
# SPEC_WORKFLOW_ARTIFACT_ROOT="var/artifacts/spec_workflows"
WORKFLOW_USE_SKILLS="true"
# Legacy aliases:
# SPEC_WORKFLOW_USE_SKILLS="true"
WORKFLOW_SKILLS_SHADOW_MODE="false"
# Legacy aliases:
# SPEC_WORKFLOW_SKILLS_SHADOW_MODE="false"
WORKFLOW_SKILLS_FALLBACK_ENABLED="true"
# Legacy aliases:
# SPEC_WORKFLOW_SKILLS_FALLBACK_ENABLED="true"
WORKFLOW_SKILLS_CANARY_PERCENT=100
# Legacy aliases:
# SPEC_WORKFLOW_SKILLS_CANARY_PERCENT=100
WORKFLOW_DEFAULT_SKILL="speckit"
WORKFLOW_DISCOVER_SKILL=""
WORKFLOW_SUBMIT_SKILL=""
WORKFLOW_PUBLISH_SKILL=""
# Legacy aliases:
# SPEC_WORKFLOW_DEFAULT_SKILL="speckit"
# SPEC_WORKFLOW_DISCOVER_SKILL=""
# SPEC_WORKFLOW_SUBMIT_SKILL=""
# SPEC_WORKFLOW_PUBLISH_SKILL=""
# Skill policy mode:
WORKFLOW_SKILL_POLICY_MODE="permissive"
# Legacy aliases:
# SPEC_WORKFLOW_SKILL_POLICY_MODE="permissive"
WORKFLOW_ALLOWED_SKILLS="speckit"
# Legacy aliases:
# SPEC_WORKFLOW_ALLOWED_SKILLS="speckit"
# Orchestrator mirror overrides to match worker shared-skills resolution:
# - local-only skills under .agents/skills/local
# - non-local/shared skills under .agents/skills (including legacy nested /skills)
MOONMIND_ORCHESTRATOR_WORKFLOW_REPO_ROOT="/workspace"
# Legacy aliases:
# MOONMIND_ORCHESTRATOR_SPEC_WORKFLOW_REPO_ROOT="/workspace"
MOONMIND_ORCHESTRATOR_WORKFLOW_SKILLS_LOCAL_MIRROR_ROOT="/workspace/.agents/skills/local"
# Legacy aliases:
# MOONMIND_ORCHESTRATOR_SPEC_SKILLS_LOCAL_MIRROR_ROOT="/workspace/.agents/skills/local"
MOONMIND_ORCHESTRATOR_WORKFLOW_SKILLS_LEGACY_MIRROR_ROOT="/workspace/.agents/skills"
# Legacy aliases:
# MOONMIND_ORCHESTRATOR_SPEC_SKILLS_LEGACY_MIRROR_ROOT="/workspace/.agents/skills"
MOONMIND_SCHEDULER_POLL_INTERVAL_MS=2000
MOONMIND_SCHEDULER_BATCH_SIZE=50
MOONMIND_SCHEDULER_MAX_BACKFILL=3
# MOONMIND_SCHEDULER_LOCK_TIMEOUT_SECONDS=10
FEATURE_FLAGS__DISABLE_TASK_TEMPLATE_CATALOG="0"
FEATURE_FLAGS__TASK_TEMPLATE_CATALOG="1"
# Legacy fallback for disabling task template catalog (prefer FEATURE_FLAGS__DISABLE_TASK_TEMPLATE_CATALOG).

# Task proposal compatibility
MOONMIND_ENABLE_TASK_PROPOSALS="true"
ENABLE_TASK_PROPOSALS="true"

# Codex shard and login configuration (Spec Kit automation workers)
CODEX_LOGIN_CHECK_IMAGE=""
CODEX_MODEL="gpt-5.3-codex"
CODEX_PROFILE=""

# Agent queue Codex worker defaults (moonmind-codex-worker)
MOONMIND_TMATE_SERVER_HOST=""
MOONMIND_CODEX_MODEL="gpt-5.3-codex"
MOONMIND_CODEX_EFFORT="high"
MOONMIND_CODEX_SANDBOX_MODE="danger-full-access"
# Gemini CLI worker auth mode:
# - api_key (default): Gemini CLI uses GEMINI_API_KEY/GOOGLE_API_KEY.
# - oauth: Gemini CLI uses cached account auth in GEMINI_HOME.
MOONMIND_GEMINI_CLI_AUTH_MODE="api_key"
GEMINI_HOME="/var/lib/gemini-auth"
GEMINI_CLI_HOME="/var/lib/gemini-auth"
# Optional worker-specific skill policy overrides.
# Leave unset to inherit WORKFLOW_* values.
# MOONMIND_DEFAULT_SKILL="speckit"
# MOONMIND_SKILL_POLICY_MODE="allowlist"
# MOONMIND_ALLOWED_SKILLS="speckit,my-private-scan"
# MOONMIND_GIT_USER_NAME=""
# MOONMIND_GIT_USER_EMAIL=""
QDRANT_API_KEY=""
QDRANT_ENABLED="true"
QDRANT_URL="http://qdrant:6333"
QDRANT_HOST="qdrant"
QDRANT_PORT=6333
RABBITMQ_USER="moonmind"
RABBITMQ_PASSWORD=""
POSTGRES_PASSWORD=""
RAG_ENABLED="true"
RAG_MAX_CONTEXT_LENGTH_CHARS=8000
RAG_SIMILARITY_TOP_K=5
VECTOR_STORE_COLLECTION_NAME="moonmind"
VECTOR_STORE_PROVIDER="qdrant"

# Provider Keys (also populate the default profile when AUTH_PROVIDER=disabled)
ANTHROPIC_API_KEY=""
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-6"
ANTHROPIC_ENABLED="true"
# Claude CLI worker auth mode:
# - api_key (default): Claude CLI uses ANTHROPIC_API_KEY.
# - oauth: Claude CLI uses cached account auth in CLAUDE_HOME.
MOONMIND_CLAUDE_CLI_AUTH_MODE="api_key"
CLAUDE_HOME="/home/app/.claude"
CLAUDE_VOLUME_PATH="/home/app/.claude"
CLAUDE_VOLUME_NAME="claude_auth_volume"
ATLASSIAN_API_KEY=""
ATLASSIAN_CONFLUENCE_ENABLED="false"
ATLASSIAN_CONFLUENCE_SPACE_KEYS=""
ATLASSIAN_JIRA_ENABLED="false"
ATLASSIAN_JIRA_FETCH_BATCH_SIZE="50"
ATLASSIAN_JIRA_JQL_QUERY=""
ATLASSIAN_USERNAME=""
ATLASSIAN_URL=""
DEFAULT_CHAT_PROVIDER="google"
DEFAULT_EMBEDDING_PROVIDER="google"
GITHUB_ENABLED="false"
GITHUB_REPOS="MoonLadderStudios/Moonmind"
GITHUB_TOKEN=""
GOOGLE_API_KEY=""
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CHAT_MODEL="models/gemini-3.1-pro"
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_EMBEDDING_DIMENSIONS=3072
GOOGLE_EMBEDDING_MODEL="gemini-embedding-001"
GOOGLE_ENABLED="true"
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="o3"
OPENAI_ENABLED="true"

# Task Proposal Notifications
TASK_PROPOSALS_NOTIFICATIONS_ENABLED=false
TASK_PROPOSALS_NOTIFICATIONS_WEBHOOK_URL=""
TASK_PROPOSALS_NOTIFICATIONS_AUTHORIZATION=""
TASK_PROPOSALS_NOTIFICATIONS_TIMEOUT_SECONDS=5
