# Deployment Settings
FASTAPI_RELOAD=""
INIT_DATABASE="true"
JWT_SECRET_KEY="replace_with_a_strong_random_jwt_secret"
ENCRYPTION_MASTER_KEY="replace_with_a_strong_random_encryption_key"
FERNET_KEY=""
LANGCHAIN_API_KEY=""
LocalData=""

# Docker-outside-Docker / container task execution
ORCHESTRATOR_DOCKER_HOST="unix:///var/run/docker.sock"
MOONMIND_WORKDIR="/work/agent_jobs"
MOONMIND_AGENT_WORKSPACES_VOLUME_NAME="agent_workspaces"
CODEX_VOLUME_PATH="/home/app/.codex"
CODEX_HOME="/home/app/.codex"
MOONMIND_WORKER_CAPABILITIES="codex,git,gh,docker,proposals_write"
MOONMIND_UNREAL_CCACHE_VOLUME_NAME="unreal_ccache_volume"
MOONMIND_UNREAL_UBT_VOLUME_NAME="unreal_ubt_volume"

LANGCHAIN_PROJECT="MoonMind"
LANGCHAIN_TRACING_V2="true"
MODEL_CACHE_REFRESH_INTERVAL=3600
MODEL_CACHE_REFRESH_INTERVAL_SECONDS=3600
MODEL_DIRECTORY="/app/model_data"
HF_ACCESS_TOKEN=""
OLLAMA_BASE_URL="http://ollama:11434"
OLLAMA_CHAT_MODEL="devstral:24b"
