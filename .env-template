OPENAI_ENABLED="true"

# Jules API
JULES_API_URL=""
JULES_API_KEY=""
JULES_ENABLED="false"
JULES_TIMEOUT_SECONDS="30.0"
JULES_RETRY_ATTEMPTS="3"
JULES_RETRY_DELAY_SECONDS="1.0"

# Task Proposal Notifications
TASK_PROPOSALS_NOTIFICATIONS_ENABLED=false
TASK_PROPOSALS_NOTIFICATIONS_WEBHOOK_URL=""
