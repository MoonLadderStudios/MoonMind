# Deployment Settings
MOONMIND_IMAGE="ghcr.io/moonladderstudios/moonmind:latest"
MOONMIND_API_HOST_PORT=7000

# Omnigent local server (MM-970, sourced from MM-968)
OMNIGENT_IMAGE="ghcr.io/omnigent-ai/omnigent-server"
OMNIGENT_IMAGE_TAG="latest"
OMNIGENT_PORT=8000
OMNIGENT_POSTGRES_USER="omnigent"
OMNIGENT_POSTGRES_PASSWORD="omnigent"
OMNIGENT_POSTGRES_DB="omnigent"
OMNIGENT_ARTIFACT_DIR="/data/artifacts"
OMNIGENT_AUTH_ENABLED=1
OMNIGENT_AUTH_PROVIDER=""
OMNIGENT_ACCOUNTS_COOKIE_SECRET=""
OMNIGENT_ACCOUNTS_BASE_URL=""
# Exact browser origins allowed to open Omnigent WebSockets or trusted-origin
# multipart requests. Leave empty for Compose's local defaults. For one custom
# browser hostname, prefer setting OMNIGENT_ACCOUNTS_BASE_URL to that origin.
# Set this only when multiple trusted browser origins are needed.
OMNIGENT_WS_ALLOWED_ORIGINS=""
OMNIGENT_ACCOUNTS_INIT_ADMIN_PASSWORD=""
OMNIGENT_ACCOUNTS_SESSION_TTL_HOURS=8
OMNIGENT_ACCOUNTS_INVITE_TTL_HOURS=72
OMNIGENT_ACCOUNTS_MAGIC_TTL_MINUTES=10
OMNIGENT_ACCOUNTS_AUTO_OPEN=0
OMNIGENT_OIDC_ISSUER=""
OMNIGENT_OIDC_CLIENT_ID=""
OMNIGENT_OIDC_CLIENT_SECRET=""
OMNIGENT_OIDC_COOKIE_SECRET=""
OMNIGENT_OIDC_SCOPES="openid profile email"
OMNIGENT_OIDC_SESSION_TTL_HOURS=8
OMNIGENT_OIDC_ALLOWED_DOMAINS=""
OMNIGENT_OIDC_LOGOUT_REDIRECT_URI=""
OMNIGENT_OIDC_ALLOW_INVITES=""
OMNIGENT_DOMAIN=""
OMNIGENT_CONFIG=""
OMNIGENT_HOST_IMAGE="ghcr.io/omnigent-ai/omnigent-host"
OMNIGENT_HOST_IMAGE_TAG="latest"
# Preserve the selected upstream host image PATH here when it differs from the
# conventional default. The tools directory is prepended idempotently.
OMNIGENT_HOST_BASE_PATH="/opt/venv/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/usr/sbin:/bin:/sbin"
# Bundle publishers create a new immutable named volume for each version.
OMNIGENT_TOOL_BUNDLE_VERSION="v1"
OMNIGENT_MOONMIND_WORKSPACE="./omnigent_workspaces/MoonMind"
# Optional dedicated hosts that expose MoonMind-managed OAuth volumes to exactly
# one matching Omnigent runtime. Separate multiple profiles with commas.
COMPOSE_PROFILES=""

# Deployment update operations run Docker Compose from the trusted agent-runtime
# worker. The worker auto-detects the host path of this checkout by inspecting
# its own bind mounts via the Docker proxy, so leaving this blank is correct on
# Linux, macOS, WSL2, and Windows. Set it to an absolute host path only to
# override auto-detection (e.g., when running the worker outside compose).
MOONMIND_DEPLOYMENT_PROJECT_DIR=""
# Filename or path of the compose file. Relative paths resolve inside the
# worker's project mount; leave blank to use docker-compose.yaml.
MOONMIND_DEPLOYMENT_COMPOSE_FILE=""
# Allowlisted deployment state files written by the trusted deployment-control
# worker. The env file is passed to Docker Compose for deployment updates.
MOONMIND_DEPLOYMENT_DESIRED_STATE_ENV_FILE="/workspace/deployment_state/.env.deploy"
MOONMIND_DEPLOYMENT_DESIRED_STATE_JSON_FILE="/workspace/deployment_state/desired-state.json"
MOONMIND_DEPLOYMENT_LOCK_DIR="/workspace/deployment_state/locks"
MOONMIND_DEPLOYMENT_PROJECT_NAME="moonmind"
# Deployment updates run on a dedicated deployment-control worker. It is
# excluded from the compose up target list so the activity runner is not
# recreated while it is applying the stack update.
MOONMIND_DEPLOYMENT_WORKER_IMAGE=""
MOONMIND_DEPLOYMENT_EXCLUDED_SERVICES="temporal-worker-deployment-control"
TEMPORAL_ACTIVITY_DEPLOYMENT_TASK_QUEUE="mm.activity.deployment"
TEMPORAL_DEPLOYMENT_WORKER_CONCURRENCY="1"
FASTAPI_RELOAD=""
INIT_DATABASE="true"
JWT_SECRET_KEY="replace_with_a_strong_random_jwt_secret"
# Leave empty for local-first startup. MoonMind will generate and persist a
# local encryption key in var/secrets/encryption_master_key (or the compose
# moonmind_secrets volume). Set this only when providing an operator-managed key.
ENCRYPTION_MASTER_KEY=""
FERNET_KEY=""
LANGCHAIN_API_KEY=""
LocalData=""

# UI Dev Server — set to the Vite dev server URL (e.g. http://127.0.0.1:5173)
# to enable live HMR during frontend development. Leave unset to serve the
# built manifest-backed dist/ bundle. Requires running `npm run ui:dev`.
MOONMIND_UI_DEV_SERVER_URL=""
# Dashboard header metadata.
# Set MOONMIND_BUILD_ID to the MoonMind image/build version you want displayed
# in the UI, for example 20260408.1703. When unset, MoonMind falls back to the
# build id baked into the Docker image at image build time.
MOONMIND_BUILD_ID=""

# Docker-outside-Docker / container task execution
MOONMIND_WORKDIR="/work/agent_jobs"
MOONMIND_AGENT_WORKSPACES_VOLUME_NAME="agent_workspaces"
CODEX_VOLUME_PATH="/home/app/.codex"
CODEX_HOME="/home/app/.codex"
MOONMIND_WORKER_CAPABILITIES="codex,git,gh,docker,proposals_write"
MOONMIND_UNREAL_CCACHE_VOLUME_NAME="unreal_ccache_volume"
MOONMIND_UNREAL_UBT_VOLUME_NAME="unreal_ubt_volume"

# Managed-runtime cleanup. These working defaults automatically delete only
# ownership-verified terminal workspaces/artifacts after retention. Set ENABLED
# to false for indefinite retention, or DRY_RUN to true to inspect candidates.
MOONMIND_MANAGED_RUNTIME_JANITOR_ENABLED="true"
MOONMIND_MANAGED_RUNTIME_JANITOR_DRY_RUN="false"
MOONMIND_MANAGED_RUNTIME_WORKSPACE_RETENTION_DAYS="30"
MOONMIND_MANAGED_RUNTIME_ARTIFACT_RETENTION_DAYS="90"
# Run/session JSON record deletion is opt-in; blank retains records indefinitely.
MOONMIND_MANAGED_RUNTIME_RECORD_RETENTION_DAYS=""

# Advanced managed-runtime cleanup tuning. The hourly schedule skips overlaps
# and catches up only its latest missed run. A 100-path pass cap lets backlog
# converge over repeated runs while keeping every pass bounded.
MOONMIND_MANAGED_RUNTIME_JANITOR_GRACE_SECONDS="3600"
MOONMIND_MANAGED_RUNTIME_JANITOR_MAX_DELETE_PATHS="100"
# Blank means no byte cap; set a positive byte count for an additional bound.
MOONMIND_MANAGED_RUNTIME_JANITOR_MAX_DELETE_BYTES=""
MOONMIND_MANAGED_RUNTIME_JANITOR_LOCK_PATH="/work/agent_jobs/.janitor.lock"
# Override only when the managed-runtime volume is mounted elsewhere.
MOONMIND_AGENT_RUNTIME_STORE="/work/agent_jobs"
MOONMIND_AGENT_RUNTIME_ARTIFACTS="/work/agent_jobs/artifacts"

# Curated PentestGPT tool (`security.pentest.run`)
# Discovery is enabled by default; the tool is visible in the dashboard and
# `/workflows/new`. This does not relax execution guardrails (approved scope is
# still required, external targets still require manual approval by default, and
# only the Claude OAuth runner profile is allowlisted). Set MOONMIND_PENTEST_ENABLED="false"
# as the operator disable override in deployments that are not approved for
# pentest operation.
MOONMIND_PENTEST_ENABLED="true"
MOONMIND_PENTEST_RUNNER_IMAGE="ghcr.io/moonladderstudios/moonmind-pentestgpt:1.0"
MOONMIND_PENTEST_ALLOWED_RUNNER_PROFILES="pentestgpt-claude-oauth"
MOONMIND_PENTEST_DEFAULT_RUNNER_PROFILE="pentestgpt-claude-oauth"
MOONMIND_PENTEST_ALLOW_CLAUDE_OAUTH_PROFILE="true"
MOONMIND_PENTEST_CLAUDE_OAUTH_RUNNER_PROFILE_ID="pentestgpt-claude-oauth"
MOONMIND_PENTEST_CLAUDE_OAUTH_PROVIDER_PROFILE_ID="pentestgpt_claude_oauth"
MOONMIND_PENTEST_CLAUDE_OAUTH_VOLUME="claude_auth_volume"
MOONMIND_PENTEST_CLAUDE_OAUTH_MOUNT_PATH="/home/pentester/.claude"
MOONMIND_PENTEST_CLAUDE_OAUTH_CREDENTIAL_PROFILE_REF="claude_anthropic"
MOONMIND_PENTEST_CLAUDE_OAUTH_SEED_PER_RUN_HOME="true"
MOONMIND_PENTEST_DEFAULT_PROVIDER_PROFILE="pentestgpt_claude_oauth"
MOONMIND_PENTEST_PROVIDER_PROFILES_FILE=""
MOONMIND_PENTEST_ENABLED_PROVIDER_PROFILES="pentestgpt_claude_oauth"
MOONMIND_PENTEST_PROVIDER_SLOT_WAIT_SECONDS="300"
MOONMIND_PENTEST_PROVIDER_LEASE_SECONDS=""
MOONMIND_PENTEST_DEFAULT_OPERATION_MODE="recon_only"
MOONMIND_PENTEST_ALLOWED_OPERATION_MODES="recon_only,validate_hypothesis"
MOONMIND_PENTEST_DEFAULT_EVIDENCE_LEVEL="standard"
MOONMIND_PENTEST_ALLOWED_EVIDENCE_LEVELS="minimal,standard,full"
MOONMIND_PENTEST_DEFAULT_TIME_BUDGET_MINUTES="60"
MOONMIND_PENTEST_MAX_TIME_BUDGET_MINUTES="480"
MOONMIND_PENTEST_REQUIRE_APPROVED_SCOPE="true"
MOONMIND_PENTEST_REQUIRE_MANUAL_APPROVAL_FOR_EXTERNAL="true"
MOONMIND_PENTEST_REQUIRE_MANUAL_APPROVAL_FOR_FULL_AUTHORIZED="true"
MOONMIND_PENTEST_ALLOW_EXTERNAL_TARGETS="true"
MOONMIND_PENTEST_TELEMETRY_ENABLED="false"

LANGCHAIN_PROJECT="MoonMind"
LANGCHAIN_TRACING_V2="true"
MODEL_CACHE_REFRESH_INTERVAL=3600
MODEL_CACHE_REFRESH_INTERVAL_SECONDS=3600
MODEL_DIRECTORY="/app/model_data"
HF_ACCESS_TOKEN=""
POSTGRES_VERSION=17
TEMPORAL_VERSION="1.29.1"
TEMPORAL_ADMINTOOLS_VERSION="1.29.1-tctl-1.18.4-cli-1.5.0"
TEMPORAL_UI_VERSION="2.34.0"
TEMPORAL_POSTGRES_VERSION=17
TEMPORAL_POSTGRES_USER="temporal"
TEMPORAL_POSTGRES_PASSWORD="temporal"
TEMPORAL_POSTGRES_DB="temporal"
TEMPORAL_VISIBILITY_DB="temporal_visibility"
TEMPORAL_ADDRESS="temporal:7233"
TEMPORAL_NAMESPACE="default"
TEMPORAL_WORKFLOW_TASK_QUEUE="mm.workflow"
TEMPORAL_USER_WORKFLOW_CONTRACT_MODE="renamed_contract"
TEMPORAL_USER_WORKFLOW_V2_TASK_QUEUE="mm.workflow.user.v2"
TEMPORAL_USER_WORKFLOW_CUTOVER_RECORD_PATH="docs/ReleaseNotes/MM-730-hard-switch-cutover.json"
TEMPORAL_USER_WORKFLOW_RELEASE_NOTES_PATH="docs/ReleaseNotes/MM-730-hard-switch-cutover.md"
TEMPORAL_ACTIVITY_ARTIFACTS_TASK_QUEUE="mm.activity.artifacts"
TEMPORAL_ACTIVITY_LLM_TASK_QUEUE="mm.activity.llm"
TEMPORAL_ACTIVITY_SANDBOX_TASK_QUEUE="mm.activity.sandbox"
TEMPORAL_ACTIVITY_INTEGRATIONS_TASK_QUEUE="mm.activity.integrations"
TEMPORAL_ACTIVITY_AGENT_RUNTIME_TASK_QUEUE="mm.activity.agent_runtime"

TEMPORAL_WORKFLOW_WORKER_CONCURRENCY=8
TEMPORAL_ARTIFACTS_WORKER_CONCURRENCY=8
TEMPORAL_LLM_WORKER_CONCURRENCY=4
TEMPORAL_SANDBOX_WORKER_CONCURRENCY=2
TEMPORAL_INTEGRATIONS_WORKER_CONCURRENCY=4
TEMPORAL_AGENT_RUNTIME_WORKER_CONCURRENCY=4
TEMPORAL_NAMESPACE_RETENTION_DAYS=90
TEMPORAL_RETENTION_MAX_STORAGE_GB=100
TEMPORAL_NUM_HISTORY_SHARDS=1
TEMPORAL_SHARD_DECISION_ACK=""
TEMPORAL_VISIBILITY_SCHEMA_DIR="/etc/temporal/schema/postgresql/v12/visibility/versioned"
TEMPORAL_DASHBOARD_SUBMIT_ENABLED=true
TEMPORAL_WORKFLOW_EDITING_ENABLED=true
TEMPORAL_UI_HOST_PORT=8088
WORKFLOW_CODEX_QUEUE="codex"
WORKFLOW_GITHUB_REPOSITORY="MoonLadderStudios/MoonMind"
WORKFLOW_GIT_USER_NAME=""
WORKFLOW_GIT_USER_EMAIL=""
WORKFLOW_ARTIFACT_ROOT="var/artifacts/workflows"
# Legacy aliases:
# WORKFLOW_ARTIFACT_ROOT="var/artifacts/workflows"
TEMPORAL_ARTIFACT_ROOT="var/artifacts/temporal_artifacts"
TEMPORAL_ARTIFACT_BACKEND="s3"
# Prefer moonmind-temporal-artifacts-s3 when using docker-compose (unique alias); avoid
# http://minio:9000 if other stacks on the same Docker network also use the name `minio`.
TEMPORAL_ARTIFACT_S3_ENDPOINT="http://moonmind-temporal-artifacts-s3:9000"
TEMPORAL_ARTIFACT_S3_PUBLIC_ENDPOINT="http://localhost:9000"
TEMPORAL_ARTIFACT_S3_BUCKET="moonmind-temporal-artifacts"
TEMPORAL_ARTIFACT_S3_ACCESS_KEY_ID="minioadmin"
TEMPORAL_ARTIFACT_S3_SECRET_ACCESS_KEY="minioadmin"
TEMPORAL_ARTIFACT_S3_REGION="us-east-1"
TEMPORAL_ARTIFACT_S3_USE_SSL="false"
TEMPORAL_ARTIFACT_PRESIGN_TTL_SECONDS=900
TEMPORAL_ARTIFACT_DIRECT_UPLOAD_MAX_BYTES=10485760
TEMPORAL_ARTIFACT_LIFECYCLE_HARD_DELETE_AFTER_SECONDS=3600
MINIO_API_PORT=9000
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"
MINIO_CONSOLE_PORT=9001
MOONMIND_IMAGE="ghcr.io/moonladderstudios/moonmind:latest"
WORKFLOW_USE_SKILLS="true"
# Legacy aliases:
# WORKFLOW_USE_SKILLS="true"
WORKFLOW_SKILLS_SHADOW_MODE="false"
# Legacy aliases:
# WORKFLOW_SKILLS_SHADOW_MODE="false"
WORKFLOW_SKILLS_FALLBACK_ENABLED="true"
# Legacy aliases:
# WORKFLOW_SKILLS_FALLBACK_ENABLED="true"
WORKFLOW_SKILLS_CANARY_PERCENT=100
# Legacy aliases:
# WORKFLOW_SKILLS_CANARY_PERCENT=100
WORKFLOW_DEFAULT_SKILL="auto"
WORKFLOW_DISCOVER_SKILL=""
WORKFLOW_SUBMIT_SKILL=""
WORKFLOW_PUBLISH_SKILL=""
# Legacy aliases:
# WORKFLOW_DEFAULT_SKILL="auto"
# WORKFLOW_DISCOVER_SKILL=""
# WORKFLOW_SUBMIT_SKILL=""
# WORKFLOW_PUBLISH_SKILL=""
# Skill policy mode:
WORKFLOW_SKILL_POLICY_MODE="permissive"
# Legacy aliases:
# WORKFLOW_SKILL_POLICY_MODE="permissive"
WORKFLOW_ALLOWED_SKILLS="auto"
# Legacy aliases:
# WORKFLOW_ALLOWED_SKILLS="auto"
# Workflow proposals
MOONMIND_ENABLE_PROPOSALS="true"

# Memory & Procedural Learning runtime controls (MM-767)
MEMORY_ENABLED="true"
MEMORY_PLANNING="off"
MEMORY_HISTORY="off"
MEMORY_LONG_TERM="off"
MEMORY_FAIL_OPEN="true"
MEMORY_CONTEXT_BUDGET_TOKENS="4096"

# Codex shard and login configuration (workflow automation workers)
CODEX_LOGIN_CHECK_IMAGE=""
CODEX_MODEL="gpt-5.3-codex"
CODEX_PROFILE=""

# Temporal sandbox runtime defaults (Codex/Claude CLIs)
MOONMIND_CODEX_MODEL="gpt-5.3-codex"
MOONMIND_CODEX_EFFORT="high"
MOONMIND_CODEX_SANDBOX_MODE="danger-full-access"
# Retry budget for transient Gemini provider capacity errors (429/RESOURCE_EXHAUSTED).
MOONMIND_GEMINI_CAPACITY_RETRY_MAX_ATTEMPTS="8"
MOONMIND_GEMINI_CAPACITY_RETRY_BASE_DELAY_SECONDS="30"
MOONMIND_GEMINI_CAPACITY_RETRY_MAX_DELAY_SECONDS="600"
# Optional worker-specific skill policy overrides.
# Leave unset to inherit WORKFLOW_* values.
# MOONMIND_DEFAULT_SKILL="auto"
# MOONMIND_SKILL_POLICY_MODE="allowlist"
# MOONMIND_ALLOWED_SKILLS="auto,my-private-scan"
# MOONMIND_GIT_USER_NAME=""
# MOONMIND_GIT_USER_EMAIL=""
QDRANT_API_KEY=""
QDRANT_ENABLED="true"
QDRANT_URL="http://qdrant:6333"
QDRANT_HOST="qdrant"
QDRANT_PORT=6333
RABBITMQ_USER="moonmind"
RABBITMQ_PASSWORD=""
POSTGRES_PASSWORD=""
RAG_ENABLED="true"
RAG_MAX_CONTEXT_LENGTH_CHARS=8000
RAG_SIMILARITY_TOP_K=5
MEMORY_ENABLED="true"
MEMORY_PLANNING="off"
MEMORY_FAIL_OPEN="true"
MEMORY_CONTEXT_BUDGET_TOKENS=2000
VECTOR_STORE_COLLECTION_NAME="moonmind"
VECTOR_STORE_PROVIDER="qdrant"

# Provider Keys (also populate the default profile when AUTH_PROVIDER=disabled)
ANTHROPIC_API_KEY=""
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-6"
ANTHROPIC_ENABLED="true"
# Claude CLI worker auth mode:
# - api_key (default): Claude CLI uses ANTHROPIC_API_KEY.
