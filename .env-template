MOONMIND_CLAUDE_CLI_AUTH_MODE="api_key"
CLAUDE_HOME="/home/app/.claude"
CLAUDE_VOLUME_PATH="/home/app/.claude"
CLAUDE_VOLUME_NAME="claude_auth_volume"

ATLASSIAN_API_KEY=""
ATLASSIAN_API_KEY_SECRET_REF=""
