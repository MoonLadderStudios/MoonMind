{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "pr": {
      "type": "object",
      "description": "Raw metadata output from gh pr view --json"
    },
    "ci": {
      "type": "object",
      "properties": {
        "isRunning": { "type": "boolean" },
        "hasFailures": { "type": "boolean" },
        "totalCheckCount": { "type": "integer" },
        "securityCheckCount": { "type": "integer" },
        "nonSecurityCheckCount": { "type": "integer" },
        "checkNames": {
          "type": "array",
          "items": { "type": "string" }
        },
        "signalQuality": { "type": "string" },
        "degradedReasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiredChecksKnown": { "type": "boolean" },
        "requiredChecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missingRequiredChecks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failedChecks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "state": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "required": [
        "isRunning",
        "hasFailures",
        "failedChecks",
        "totalCheckCount",
        "securityCheckCount",
        "nonSecurityCheckCount",
        "checkNames",
        "signalQuality",
        "degradedReasons",
        "requiredChecksKnown",
        "requiredChecks",
        "missingRequiredChecks"
      ]
    },
    "commentsFetch": {
      "type": "object",
      "properties": {
        "succeeded": { "type": "boolean" },
        "source": { "type": "string" }
      },
      "required": ["succeeded", "source"]
    },
    "commentsSummary": {
      "type": "object",
      "properties": {
        "classificationVersion": { "type": "integer" },
        "total": { "type": "integer" },
        "reviewCommentCount": { "type": "integer" },
        "issueCommentCount": { "type": "integer" },
        "reviewBodyCount": { "type": "integer" },
        "actionableCommentCount": { "type": "integer" },
        "includeBotReviewComments": { "type": "boolean" },
        "humanCommentCount": { "type": "integer" },
        "botCommentCount": { "type": "integer" },
        "hasActionableComments": { "type": "boolean" },
        "actionableCommentIds": {
          "type": "array",
          "items": {}
        },
        "nonActionableReasonCounts": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "classifiedComments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {},
              "type": { "type": ["string", "null"] },
              "user": { "type": ["string", "null"] },
              "url": { "type": ["string", "null"] },
              "path": { "type": ["string", "null"] },
              "line": { "type": ["integer", "null"] },
              "actionable": { "type": "boolean" },
              "reason": { "type": "string" }
            },
            "required": ["actionable", "reason"]
          }
        }
      },
      "required": [
        "classificationVersion",
        "total",
        "reviewCommentCount",
        "issueCommentCount",
        "reviewBodyCount",
        "actionableCommentCount",
        "includeBotReviewComments",
        "humanCommentCount",
        "botCommentCount",
        "hasActionableComments",
        "actionableCommentIds",
        "nonActionableReasonCounts",
        "classifiedComments"
      ]
    },
    "comments": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "required": ["pr", "ci", "commentsFetch", "comments", "commentsSummary"]
}
