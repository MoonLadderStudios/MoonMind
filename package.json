{
  "name": "moonmind",
  "version": "1.0.0",
  "description": "**MoonMind is a self-hosted AI orchestration hub for chat, memory, and automation. It combines multi-provider LLM routing, retrieval-augmented generation, and Temporal-backed workflows that can run skills-based automation across your code and infrastructure.**",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate": "npm run api:types",
    "ui:dev": "vite --config frontend/vite.config.ts",
    "ui:clean-dist": "node -e \"require('node:fs').rmSync(require('node:path').join('api_service','static','task_dashboard','dist'),{recursive:true,force:true})\"",
    "ui:build": "vite build --config frontend/vite.config.ts",
    "ui:build:check": "npm run ui:clean-dist && npm run ui:build && npm run ui:verify-manifest",
    "ui:verify-manifest": "bash tools/run_repo_python.sh tools/verify_vite_manifest.py",
    "contracts:check": "npm run api:types:check",
    "ui:typecheck": "tsc --noEmit -p frontend/tsconfig.json",
    "ui:lint": "eslint -c frontend/eslint.config.mjs frontend/src",
    "ui:test": "vitest run --config frontend/vite.config.ts",
    "ui:test:watch": "vitest --config frontend/vite.config.ts",
    "api:types": "bash tools/run_repo_python.sh tools/generate_openapi_types.py",
    "api:types:check": "npm run api:types && git diff --exit-code -- frontend/src/generated/openapi.ts",
    "frontend:ci": "npm run ui:typecheck && npm run ui:lint && npm run ui:test && npm run ui:build:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoonLadderStudios/MoonMind.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MoonLadderStudios/MoonMind/issues"
  },
  "homepage": "https://github.com/MoonLadderStudios/MoonMind#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@tanstack/react-query": "^5.95.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "anser": "^2.3.5",
    "html2canvas": "^1.4.1",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-virtuoso": "^4.18.4",
    "zod": "^4.3.6"
  }
}
