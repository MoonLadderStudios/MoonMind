{
  "name": "moonmind",
  "version": "1.0.0",
  "description": "**MoonMind is a self-hosted AI orchestration hub for chat, memory, and automation. It combines multi-provider LLM routing, retrieval-augmented generation, and Temporal-backed workflows that can run skills-based automation across your code and infrastructure.**",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dashboard:css": "tailwindcss -i api_service/static/task_dashboard/dashboard.tailwind.css -o api_service/static/task_dashboard/dashboard.css",
    "dashboard:css:min": "tailwindcss -i api_service/static/task_dashboard/dashboard.tailwind.css -o api_service/static/task_dashboard/dashboard.css --minify",
    "dashboard:css:watch": "tailwindcss -i api_service/static/task_dashboard/dashboard.tailwind.css -o api_service/static/task_dashboard/dashboard.css --watch",
    "ui:dev": "vite --config frontend/vite.config.ts",
    "ui:build": "vite build --config frontend/vite.config.ts",
    "ui:dist:check": "git diff --exit-code -- api_service/static/task_dashboard/dist/",
    "ui:typecheck": "tsc --noEmit -p frontend/tsconfig.json",
    "ui:lint": "eslint -c frontend/eslint.config.mjs frontend/src",
    "ui:test": "vitest run --config frontend/vite.config.ts",
    "ui:test:watch": "vitest --config frontend/vite.config.ts",
    "api:types": "python tools/export_openapi.py > openapi.json && npx openapi-typescript openapi.json -o frontend/src/generated/openapi.ts",
    "ci:test": "npm run ui:typecheck && npm run ui:lint && npm run ui:test && npm run ui:build && npm run api:types:check",
    "api:types:check": "npm run api:types && git diff --exit-code -- frontend/src/generated/openapi.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoonLadderStudios/MoonMind.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MoonLadderStudios/MoonMind/issues"
  },
  "homepage": "https://github.com/MoonLadderStudios/MoonMind#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  }
}