{
  "$defs": {
    "DataSourceAuth": {
      "additionalProperties": true,
      "description": "Secret references for a data source (``${ENV}`` interpolated).",
      "properties": {},
      "title": "DataSourceAuth",
      "type": "object"
    },
    "DataSourceConfig": {
      "description": "A single data source reader definition.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "auth": {
          "anyOf": [
            {
              "$ref": "#/$defs/DataSourceAuth"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "schedule": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schedule"
        }
      },
      "required": [
        "id",
        "type"
      ],
      "title": "DataSourceConfig",
      "type": "object"
    },
    "EmbeddingsConfig": {
      "description": "Mandatory embedding provider settings.",
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "batchSize": {
          "default": 128,
          "minimum": 1,
          "title": "Batchsize",
          "type": "integer"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "EmbeddingsConfig",
      "type": "object"
    },
    "EvaluationConfig": {
      "description": "Evaluation settings.",
      "properties": {
        "datasets": {
          "items": {
            "$ref": "#/$defs/EvaluationDataset"
          },
          "title": "Datasets",
          "type": "array"
        },
        "metrics": {
          "items": {
            "$ref": "#/$defs/EvaluationMetric"
          },
          "title": "Metrics",
          "type": "array"
        }
      },
      "title": "EvaluationConfig",
      "type": "object"
    },
    "EvaluationDataset": {
      "description": "A golden dataset for retrieval evaluation.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        }
      },
      "required": [
        "name",
        "path"
      ],
      "title": "EvaluationDataset",
      "type": "object"
    },
    "EvaluationMetric": {
      "description": "A retrieval metric with optional threshold gate.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "threshold": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Threshold"
        }
      },
      "required": [
        "name"
      ],
      "title": "EvaluationMetric",
      "type": "object"
    },
    "IndexConfig": {
      "description": "A vector/summary/keyword index definition.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "default": "VectorStoreIndex",
          "title": "Type",
          "type": "string"
        },
        "sources": {
          "items": {
            "type": "string"
          },
          "title": "Sources",
          "type": "array"
        },
        "persist": {
          "anyOf": [
            {
              "$ref": "#/$defs/IndexPersist"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id"
      ],
      "title": "IndexConfig",
      "type": "object"
    },
    "IndexPersist": {
      "description": "Persistence target for an index.",
      "properties": {
        "path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        }
      },
      "title": "IndexPersist",
      "type": "object"
    },
    "LLMConfig": {
      "description": "Optional LLM provider for answer generation.",
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "temperature": {
          "default": 0.0,
          "maximum": 2.0,
          "minimum": 0.0,
          "title": "Temperature",
          "type": "number"
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "title": "LLMConfig",
      "type": "object"
    },
    "ManifestMetadata": {
      "description": "Manifest identity and ownership.",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "owner": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Owner"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "name"
      ],
      "title": "ManifestMetadata",
      "type": "object"
    },
    "RerankerConfig": {
      "description": "Optional reranker for retrieval.",
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "topK": {
          "default": 5,
          "minimum": 1,
          "title": "Topk",
          "type": "integer"
        }
      },
      "required": [
        "type"
      ],
      "title": "RerankerConfig",
      "type": "object"
    },
    "RetrieverConfig": {
      "description": "Named retriever (Vector or Hybrid).",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        },
        "indices": {
          "items": {
            "type": "string"
          },
          "title": "Indices",
          "type": "array"
        },
        "params": {
          "anyOf": [
            {
              "$ref": "#/$defs/RetrieverParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reranker": {
          "anyOf": [
            {
              "$ref": "#/$defs/RerankerConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "id",
        "type",
        "indices"
      ],
      "title": "RetrieverConfig",
      "type": "object"
    },
    "RetrieverParams": {
      "description": "Retriever tuning knobs.",
      "properties": {
        "topK": {
          "default": 8,
          "minimum": 1,
          "title": "Topk",
          "type": "integer"
        },
        "alpha": {
          "default": 0.5,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Alpha",
          "type": "number"
        }
      },
      "title": "RetrieverParams",
      "type": "object"
    },
    "RunConfig": {
      "description": "Execution parameters.",
      "properties": {
        "concurrency": {
          "default": 6,
          "minimum": 1,
          "title": "Concurrency",
          "type": "integer"
        },
        "batchSize": {
          "default": 128,
          "minimum": 1,
          "title": "Batchsize",
          "type": "integer"
        },
        "errorPolicy": {
          "default": "continue",
          "title": "Errorpolicy",
          "type": "string"
        },
        "dryRun": {
          "default": false,
          "title": "Dryrun",
          "type": "boolean"
        }
      },
      "title": "RunConfig",
      "type": "object"
    },
    "SecurityConfig": {
      "description": "Security and compliance settings.",
      "properties": {
        "piiRedaction": {
          "default": false,
          "title": "Piiredaction",
          "type": "boolean"
        },
        "allowlistMetadata": {
          "items": {
            "type": "string"
          },
          "title": "Allowlistmetadata",
          "type": "array"
        }
      },
      "title": "SecurityConfig",
      "type": "object"
    },
    "SplitterConfig": {
      "description": "Text splitter / chunker settings.",
      "properties": {
        "type": {
          "default": "TokenTextSplitter",
          "title": "Type",
          "type": "string"
        },
        "chunkSize": {
          "default": 1000,
          "minimum": 1,
          "title": "Chunksize",
          "type": "integer"
        },
        "chunkOverlap": {
          "default": 100,
          "minimum": 0,
          "title": "Chunkoverlap",
          "type": "integer"
        }
      },
      "title": "SplitterConfig",
      "type": "object"
    },
    "TransformsConfig": {
      "description": "Document transforms applied before indexing.",
      "properties": {
        "htmlToText": {
          "default": false,
          "title": "Htmltotext",
          "type": "boolean"
        },
        "splitter": {
          "anyOf": [
            {
              "$ref": "#/$defs/SplitterConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "enrichMetadata": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Enrichmetadata",
          "type": "array"
        }
      },
      "title": "TransformsConfig",
      "type": "object"
    },
    "VectorStoreConfig": {
      "description": "Vector store destination.",
      "properties": {
        "type": {
          "title": "Type",
          "type": "string"
        },
        "indexName": {
          "title": "Indexname",
          "type": "string"
        },
        "connection": {
          "$ref": "#/$defs/VectorStoreConnection"
        }
      },
      "required": [
        "type",
        "indexName"
      ],
      "title": "VectorStoreConfig",
      "type": "object"
    },
    "VectorStoreConnection": {
      "additionalProperties": true,
      "description": "Flexible connection parameters for a vector store.",
      "properties": {},
      "title": "VectorStoreConnection",
      "type": "object"
    }
  },
  "description": "Top-level v0 manifest document.\n\nValidates against the schema described in\n``docs/RAG/LlamaIndexManifestSystem.md`` \u00a73.",
  "properties": {
    "version": {
      "const": "v0",
      "default": "v0",
      "title": "Version",
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ManifestMetadata"
    },
    "llm": {
      "anyOf": [
        {
          "$ref": "#/$defs/LLMConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "embeddings": {
      "$ref": "#/$defs/EmbeddingsConfig"
    },
    "vectorStore": {
      "$ref": "#/$defs/VectorStoreConfig"
    },
    "dataSources": {
      "items": {
        "$ref": "#/$defs/DataSourceConfig"
      },
      "minItems": 1,
      "title": "Datasources",
      "type": "array"
    },
    "transforms": {
      "anyOf": [
        {
          "$ref": "#/$defs/TransformsConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "indices": {
      "items": {
        "$ref": "#/$defs/IndexConfig"
      },
      "minItems": 1,
      "title": "Indices",
      "type": "array"
    },
    "retrievers": {
      "items": {
        "$ref": "#/$defs/RetrieverConfig"
      },
      "minItems": 1,
      "title": "Retrievers",
      "type": "array"
    },
    "postprocessors": {
      "items": {
        "additionalProperties": true,
        "type": "object"
      },
      "title": "Postprocessors",
      "type": "array"
    },
    "evaluation": {
      "anyOf": [
        {
          "$ref": "#/$defs/EvaluationConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "run": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "observability": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observability"
    },
    "security": {
      "anyOf": [
        {
          "$ref": "#/$defs/SecurityConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "scheduling": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scheduling"
    }
  },
  "required": [
    "metadata",
    "embeddings",
    "vectorStore",
    "dataSources",
    "indices",
    "retrievers"
  ],
  "title": "ManifestV0",
  "type": "object"
}
